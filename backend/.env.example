# ============================================
# BACKEND ENVIRONMENT CONFIGURATION
# ============================================

# SERVER CONFIGURATION
PORT=5001
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION CONFIGURATION
# ============================================
# JWT Secret keys - generate strong random strings in production
JWT_SECRET=your_jwt_secret_key_min_32_characters
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your_refresh_secret_key_min_32_characters
REFRESH_TOKEN_EXPIRE=7d

# ============================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ============================================
# Gmail account credentials
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Alternative names for email config
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@fashionhub.com

# Admin email for notifications
ADMIN_EMAIL=admin@fashionhub.com

# ============================================
# CLOUDINARY CONFIGURATION (Image Storage)
# ============================================
# Cloudinary cloud storage for product images
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# ============================================
# PAGINATION CONFIGURATION
# ============================================
# Default items per page for listings
ITEMS_PER_PAGE=12

# ============================================
# PAYMENT CONFIGURATION
# ============================================
# bKash merchant number for payment processing
BKASH_NUMBER=01XXXXXXXXX

# ============================================
# OPTIONAL: AI & EMBEDDING SERVICES
# ============================================
# Groq API for AI features (optional)
# GROQ_API_KEY=your_groq_api_key

# Cohere API for embeddings (optional)
# COHERE_API_KEY=your_cohere_api_key

# Pinecone configuration for vector database (optional)
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_INDEX=your_pinecone_index_url
# PINECONE_INDEX_NAME=your_index_name

# ============================================
# LOGGING CONFIGURATION (Optional)
# ============================================
# LOG_LEVEL=debug
